# NetVisor Environment Settings Template
# Copy this file to .env and configure your variables

# Backend Server Configuration
NETVISOR_RELOAD=false

# Socket Configuration
PORT=8000
HOST=0.0.0.0

# Database Configuration (if using Postgres or another external DB)
# DATABASE_URL=mysql+mysqlconnector://user:pass@localhost:3306/netvisor

# Authentication Secrets (Generate secure random values for production)
SECRET_KEY=generate_a_secure_key_here
AGENT_API_KEY=generate_an_agent_key_here

# Organization Defaults
NETVISOR_DEFAULT_ORGANIZATION_ID=default-org-id

# Agent Discovery & Polling Tweaks
NETVISOR_AGENT_HEARTBEAT_SECONDS=10
NETVISOR_WEB_PROXY_PORT=8899
NETVISOR_WEB_POLICY_REFRESH_SECONDS=30
