# NetVisor Environment Settings Template
# Copy this file to .env and configure your variables

# Backend / API
NETVISOR_SECRET_KEY=generate_a_secure_key_here
NETVISOR_AGENT_MASTER_KEY=generate_a_separate_agent_master_key_here
NETVISOR_GATEWAY_MASTER_KEY=generate_a_separate_gateway_master_key_here
NETVISOR_PUBLIC_HOSTNAME=
NETVISOR_CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
NETVISOR_LOG_LEVEL=INFO
NETVISOR_SINGLE_ORG_MODE=true
NETVISOR_DEFAULT_ORGANIZATION_ID=default-org-id
NETVISOR_ALLOW_SELF_REGISTER=false
NETVISOR_ACCESS_TOKEN_MINUTES=30
NETVISOR_AUTH_COOKIE_NAME=netvisor_session
NETVISOR_AUTH_COOKIE_SAMESITE=lax
NETVISOR_AUTH_COOKIE_SECURE=false
NETVISOR_AUTH_COOKIE_DOMAIN=
NETVISOR_AUTH_COOKIE_PATH=/
NETVISOR_CSRF_COOKIE_NAME=XSRF-TOKEN
NETVISOR_CSRF_HEADER_NAME=X-XSRF-TOKEN
NETVISOR_RELEASE_VERSION=
NETVISOR_RELEASE_CHANNEL=dev
NETVISOR_GIT_COMMIT=
NETVISOR_BUILD_TIMESTAMP=
NETVISOR_LOGIN_LOCKOUT_THRESHOLD=5
NETVISOR_LOGIN_LOCKOUT_MINUTES=15
NETVISOR_AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=20
NETVISOR_AUTH_REGISTER_RATE_LIMIT_PER_MINUTE=5
NETVISOR_AGENT_BOOTSTRAP_RATE_LIMIT_PER_MINUTE=30
NETVISOR_AGENT_CONTROL_RATE_LIMIT_PER_MINUTE=240
NETVISOR_AGENT_FLOW_RATE_LIMIT_PER_MINUTE=1200
NETVISOR_ADMIN_MUTATION_RATE_LIMIT_PER_MINUTE=30
NETVISOR_FLOW_WORKER_MODE=embedded
NETVISOR_FLOW_WORKER_POLL_SECONDS=1
NETVISOR_FLOW_WORKER_CLAIM_LIMIT=10
NETVISOR_FLOW_WORKER_HEARTBEAT_SECONDS=5
NETVISOR_FLOW_WORKER_ALIVE_SECONDS=15
NETVISOR_FLOW_INGEST_MAX_ATTEMPTS=5
NETVISOR_FLOW_INGEST_RETRY_SECONDS=5
NETVISOR_FLOW_INGEST_CLAIM_TTL_SECONDS=120
NETVISOR_FLOW_INGEST_MAX_PENDING_FLOWS=50000
NETVISOR_FLOW_INGEST_MAX_LAG_SECONDS=30
NETVISOR_BACKUP_RETENTION_DAYS=30

# Database
NETVISOR_DB_HOST=localhost
NETVISOR_DB_USER=root
NETVISOR_DB_PASSWORD=change_me
NETVISOR_DB_NAME=network_security

# Bootstrap admin
NETVISOR_BOOTSTRAP_ADMIN_USERNAME=admin
NETVISOR_BOOTSTRAP_ADMIN_PASSWORD=change_me

# Agent / gateway authentication
AGENT_API_KEY=generate_an_agent_key_here
GATEWAY_API_KEY=generate_a_gateway_bootstrap_key_here
NETVISOR_AGENT_NONCE_TTL_SECONDS=300
NETVISOR_AGENT_MAX_CLOCK_SKEW_SECONDS=60
NETVISOR_BACKEND_TLS_PINS_JSON=[{"pin_type":"spki_sha256","pin_sha256":"REPLACE_WITH_BACKEND_PUBLIC_KEY_PIN","status":"active"}]
NETVISOR_TRUST_PROXY_HEADERS=false
NETVISOR_FORWARDED_ALLOW_IPS=127.0.0.1
NETVISOR_ALLOW_LAN_HTTP=false

# Runtime behavior
NETVISOR_RESET_RUNTIME_ON_STARTUP=false
NETVISOR_BACKUP_AND_RESET_ON_SHUTDOWN=false
NETVISOR_GEOIP_ASN_DB_PATH=database/GeoLite2-ASN.mmdb

# Packet capture
NETVISOR_CAPTURE_BACKEND=auto
NETVISOR_CAPTURE_INTERFACE=
NETVISOR_AGENT_CAPTURE_BACKEND=auto
NETVISOR_AGENT_CAPTURE_INTERFACE=
NETVISOR_GATEWAY_CAPTURE_BACKEND=auto
NETVISOR_GATEWAY_CAPTURE_INTERFACE=
NETVISOR_PACKET_TRACE=false
NETVISOR_FLOW_FLUSH_INTERVAL_SECONDS=5
NETVISOR_FLOW_CLEANUP_INTERVAL_SECONDS=5
NETVISOR_FLOW_MAX_ACTIVE_FLOWS=50000
NETVISOR_FLOW_QUEUE_STATUS_CACHE_SECONDS=1

# Agent DPI / proxy
NETVISOR_WEB_PROXY_PORT=8899
NETVISOR_WEB_POLICY_REFRESH_SECONDS=30
NETVISOR_AGENT_HEARTBEAT_SECONDS=10
