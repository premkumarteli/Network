[Unit]
Description=NetVisor Managed Endpoint Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=netvisor-agent
Group=netvisor-agent
WorkingDirectory=/opt/netvisor/agent
EnvironmentFile=-/opt/netvisor/agent/.env
ExecStart=/usr/bin/env python3 /opt/netvisor/agent/run_agent.py
Restart=on-failure
RestartSec=5
LimitNOFILE=65536
AmbientCapabilities=CAP_NET_RAW CAP_NET_ADMIN
CapabilityBoundingSet=CAP_NET_RAW CAP_NET_ADMIN
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
